VITE_API_BASE_URL=https://me-and-doctor-backend-production.up.railway.app

# MSG91 OTP Widget (client-side) — tokenAuth is safe to expose in the
# frontend, this is what MSG91's widget expects. The main MSG91 Authkey
# must NEVER go here — it stays backend-only (used to re-verify the
# widget's access-token server-side).
VITE_MSG91_WIDGET_ID=
VITE_MSG91_TOKEN_AUTH=
